class H(http.server.SimpleHTTPRequestHandler):
  def do_GET(self):
    if self.path == '/api/status':
      self.send_response(200)
      self.send_header('Content-type','application/json')
      self.end_headers()
      s = {'ram':'N/A','disk':'N/A','uptime':'N/A','ollama':False,'version':'0.2.0'}
      try: s['ram']=subprocess.check_output(\"free -h|awk '/^Mem:/{print \\\$3\\\"/\\\"\\\$2}'\",shell=True).decode().strip()
      except: pass
      try: s['disk']=subprocess.check_output(\"df -h /|awk 'NR==2{print \\\$3\\\"/\\\"\\\$2}'\",shell=True).decode().strip()
      except: pass
      try: s['uptime']=subprocess.check_output('uptime -p',shell=True).decode().strip().replace('up ','')
      except: pass
      try: s['ollama']=subprocess.run(['curl','-s','--max-time','2','http://localhost:11434'],capture_output=True).returncode==0
      except: pass
      self.wfile.write(json.dumps(s).encode())
    else:
      self.send_response(200)
      self.send_header('Content-type','text/html;charset=utf-8')
      self.end_headers()
      self.wfile.write(HTML.encode())
  def log_message(self,*a): pass

print(f'[y7-web] Dashboard at http://localhost:{PORT}')
import socketserver
socketserver.TCPServer((\"\",PORT),H).serve_forever()" && echo "y7-web stopped" || echo "y7-web: python3 required"
