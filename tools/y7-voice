#!/bin/bash
set -e

VERSION="1.0.0"
LANG="${Y7_LANG:-en}"
VOICE_DIR="${Y7_VOICE_DIR:-$HOME/.y7os/voice}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

msg() { echo -e "${GREEN}[y7-voice]${NC} $1"; }
warn() { echo -e "${YELLOW}[warning]${NC} $1"; }
error() { echo -e "${RED}[error]${NC} $1"; exit 1; }

show_help() {
    if [ "$LANG" = "ar" ]; then
        cat << 'EOF'
y7-voice — واجهة صوتية للذكاء الاصطناعي

الاستخدام:
  y7-voice [أمر] [خيارات]

الأوامر:
  chat        محادثة صوتية تفاعلية
  listen      استمع وحول إلى نص
  speak       حول النص إلى صوت
  transcribe  حول ملف صوتي إلى نص
  install     تثبيت المكونات الصوتية

خيارات:
  --model     نموذج Whisper (tiny/base/small/medium)
  --voice     صوت TTS (افتراضي: en_US-lessac-medium)
  --help      عرض المساعدة
EOF
    else
        cat << 'EOF'
y7-voice — Voice interface for AI

Usage:
  y7-voice [command] [options]

Commands:
  chat        Interactive voice chat
  listen      Listen and transcribe
  speak       Text to speech
  transcribe  Transcribe audio file
  install     Install voice components
  status      Show installation status

Options:
  --model     Whisper model (tiny/base/small/medium)
  --voice     TTS voice (default: en_US-lessac-medium)
  --lang      Language (en/ar)
  --help      Show this help

Examples:
  y7-voice install
  y7-voice chat
  y7-voice listen
  y7-voice speak "Hello, how are you?"
  y7-voice transcribe recording.wav
EOF
    fi
}

check_audio() {
    # Check for audio tools
    if ! command -v arecord &>/dev/null && ! command -v sox &>/dev/null; then
        warn "No audio recording tool found"
        echo "Install with: sudo apt install alsa-utils sox"
        return 1
    fi

    if ! command -v aplay &>/dev/null && ! command -v play &>/dev/null; then
        warn "No audio playback tool found"
        echo "Install with: sudo apt install alsa-utils sox"
        return 1
    fi

    return 0
}

install_voice() {
    msg "Installing voice components..."

    mkdir -p "$VOICE_DIR"

    # Install Python dependencies
    msg "Installing Python packages..."
    pip3 install --quiet openai-whisper piper-tts sounddevice numpy 2>/dev/null || {
        warn "Some packages failed to install"
    }

    # Download Whisper model
    msg "Downloading Whisper model (tiny)..."
    python3 -c "import whisper; whisper.load_model('tiny')" 2>/dev/null || {
        warn "Could not download Whisper model"
    }

    # Download Piper voice
    msg "Downloading TTS voice..."
    mkdir -p "$VOICE_DIR/voices"

    if [ "$LANG" = "ar" ]; then
        # Arabic voice
        VOICE_URL="https://huggingface.co/rhasspy/piper-voices/resolve/main/ar/ar_JO/kareem/medium/ar_JO-kareem-medium.onnx"
        VOICE_NAME="ar_JO-kareem-medium"
    else
        # English voice
        VOICE_URL="https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx"
        VOICE_NAME="en_US-lessac-medium"
    fi

    curl -fsSL "$VOICE_URL" -o "$VOICE_DIR/voices/$VOICE_NAME.onnx" 2>/dev/null || warn "Could not download voice"
    curl -fsSL "${VOICE_URL}.json" -o "$VOICE_DIR/voices/$VOICE_NAME.onnx.json" 2>/dev/null || true

    # Install system audio tools
    msg "Installing system audio tools..."
    if command -v apt &>/dev/null; then
        sudo apt install -y alsa-utils sox pulseaudio 2>/dev/null || warn "Could not install audio tools"
    fi

    msg "Voice components installed!"
    echo ""
    echo "Run 'y7-voice status' to verify installation"
}

show_status() {
    echo "=== Y7 Voice Status ==="
    echo ""

    # Whisper
    echo "Speech-to-Text (Whisper):"
    if python3 -c "import whisper" 2>/dev/null; then
        echo "  ✓ Whisper installed"
    else
        echo "  ✗ Whisper not installed"
    fi

    # Piper TTS
    echo ""
    echo "Text-to-Speech (Piper):"
    if python3 -c "import piper" 2>/dev/null; then
        echo "  ✓ Piper installed"
    else
        echo "  ✗ Piper not installed"
    fi

    # Voices
    echo ""
    echo "Voices:"
    if [ -d "$VOICE_DIR/voices" ]; then
        for voice in "$VOICE_DIR/voices"/*.onnx; do
            [ -f "$voice" ] && echo "  ✓ $(basename "$voice" .onnx)"
        done
    else
        echo "  No voices downloaded"
    fi

    # Audio
    echo ""
    echo "Audio:"
    command -v arecord &>/dev/null && echo "  ✓ arecord (recording)" || echo "  ✗ arecord"
    command -v aplay &>/dev/null && echo "  ✓ aplay (playback)" || echo "  ✗ aplay"
}

listen_and_transcribe() {
    local DURATION="${1:-5}"

    check_audio || return 1

    msg "Listening for ${DURATION} seconds... (speak now)"

    # Record audio
    TEMP_FILE=$(mktemp --suffix=.wav)

    if command -v arecord &>/dev/null; then
        arecord -d "$DURATION" -f cd -t wav "$TEMP_FILE" 2>/dev/null
    elif command -v sox &>/dev/null; then
        sox -d -r 16000 -c 1 "$TEMP_FILE" trim 0 "$DURATION" 2>/dev/null
    fi

    msg "Transcribing..."

    # Transcribe with Whisper
    RESULT=$(python3 << PYTHON
import whisper
import sys

model = whisper.load_model("tiny")
result = model.transcribe("$TEMP_FILE")
print(result["text"])
PYTHON
    )

    rm -f "$TEMP_FILE"

    echo ""
    echo "You said: $RESULT"
    echo ""

    echo "$RESULT"
}

speak_text() {
    local TEXT="$1"

    if [ -z "$TEXT" ]; then
        error "Usage: y7-voice speak \"text to speak\""
    fi

    # Find voice file
    if [ "$LANG" = "ar" ]; then
        VOICE_FILE="$VOICE_DIR/voices/ar_JO-kareem-medium.onnx"
    else
        VOICE_FILE="$VOICE_DIR/voices/en_US-lessac-medium.onnx"
    fi

    if [ ! -f "$VOICE_FILE" ]; then
        warn "Voice not found. Using espeak fallback..."
        if command -v espeak &>/dev/null; then
            espeak "$TEXT"
        else
            error "No TTS available. Run: y7-voice install"
        fi
        return
    fi

    # Generate and play audio
    TEMP_FILE=$(mktemp --suffix=.wav)

    echo "$TEXT" | python3 -c "
import sys
from piper import PiperVoice

voice = PiperVoice.load('$VOICE_FILE')
with open('$TEMP_FILE', 'wb') as f:
    voice.synthesize(sys.stdin.read(), f)
" 2>/dev/null

    # Play audio
    if command -v aplay &>/dev/null; then
        aplay "$TEMP_FILE" 2>/dev/null
    elif command -v play &>/dev/null; then
        play "$TEMP_FILE" 2>/dev/null
    fi

    rm -f "$TEMP_FILE"
}

transcribe_file() {
    local AUDIO_FILE="$1"
    local MODEL="${2:-tiny}"

    if [ -z "$AUDIO_FILE" ] || [ ! -f "$AUDIO_FILE" ]; then
        error "Usage: y7-voice transcribe <audio-file>"
    fi

    msg "Transcribing: $AUDIO_FILE"

    python3 << PYTHON
import whisper

model = whisper.load_model("$MODEL")
result = model.transcribe("$AUDIO_FILE")
print(result["text"])
PYTHON
}

voice_chat() {
    msg "Starting voice chat... (Ctrl+C to exit)"
    echo ""
    echo "Speak after the beep, wait for response."
    echo ""

    check_audio || return 1

    while true; do
        # Beep
        echo -e "\a"

        # Listen
        USER_INPUT=$(listen_and_transcribe 5 2>/dev/null | tail -1)

        if [ -z "$USER_INPUT" ]; then
            warn "Didn't catch that. Try again."
            continue
        fi

        # Check for exit
        if echo "$USER_INPUT" | grep -qi "exit\|quit\|bye\|stop"; then
            speak_text "Goodbye!"
            break
        fi

        # Get AI response
        msg "Thinking..."
        RESPONSE=$(y7-ai "$USER_INPUT" 2>/dev/null)

        echo ""
        echo "AI: $RESPONSE"
        echo ""

        # Speak response
        speak_text "$RESPONSE"

        sleep 1
    done
}

# Main
case "${1:-}" in
    install)
        install_voice
        ;;
    status)
        show_status
        ;;
    chat)
        voice_chat
        ;;
    listen)
        shift
        listen_and_transcribe "$@"
        ;;
    speak|say)
        shift
        speak_text "$*"
        ;;
    transcribe)
        shift
        transcribe_file "$@"
        ;;
    -h|--help|help)
        show_help
        ;;
    "")
        show_help
        ;;
    *)
        # Treat as text to speak
        speak_text "$*"
        ;;
esac
