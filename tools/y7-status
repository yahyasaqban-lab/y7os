#!/bin/bash
# ─────────────────────────────────────────────────────────────
#  y7-status — Y7 OS System Dashboard
#  github.com/yahyasaqban-lab/y7os
#  MIT License
# ─────────────────────────────────────────────────────────────

# ── Colors ────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

# ── Language ──────────────────────────────────────────────────
LANG_AR=false
[[ "$1" == "--lang" && "$2" == "ar" ]] && LANG_AR=true
[[ "$LANG" == ar* ]] && LANG_AR=true

# ── System Info ───────────────────────────────────────────────
ram_used=$(free -m | awk '/^Mem:/{print $3}')
ram_total=$(free -m | awk '/^Mem:/{print $2}')
ram_free=$(free -m | awk '/^Mem:/{print $7}')
ram_pct=$((ram_used * 100 / ram_total))

cpu_pct=$(top -bn1 | grep "Cpu(s)" | awk '{print int($2)}' 2>/dev/null || echo 0)
cpu_cores=$(nproc)
cpu_model=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "Unknown")

disk_free=$(df -BG / | awk 'NR==2{print $4}' | tr -d 'G')
disk_total=$(df -BG / | awk 'NR==2{print $2}' | tr -d 'G')
disk_pct=$(df / | awk 'NR==2{print $5}' | tr -d '%')

uptime_str=$(uptime -p 2>/dev/null | sed 's/up //' || uptime | awk -F'up ' '{print $2}' | awk -F',' '{print $1}')

# ── Bar drawing ───────────────────────────────────────────────
bar() {
  local pct=$1 len=20
  local filled=$((pct * len / 100))
  local empty=$((len - filled))
  local color=$GREEN
  [ $pct -gt 70 ] && color=$YELLOW
  [ $pct -gt 90 ] && color=$RED
  printf "${color}"
  for ((i=0; i<filled; i++)); do printf '█'; done
  printf "${NC}"
  for ((i=0; i<empty; i++)); do printf '░'; done
}

# ── Service Status ────────────────────────────────────────────
check_ollama() {
  if command -v ollama &>/dev/null; then
    if curl -s --max-time 1 http://localhost:11434 &>/dev/null; then
      local model=$(ollama ps 2>/dev/null | tail -n1 | awk '{print $1}')
      [ -n "$model" ] && echo "✅ Running ($model)" || echo "✅ Running"
    else
      echo "⭕ Installed (not running)"
    fi
  else
    echo "❌ Not installed"
  fi
}

check_docker() {
  if command -v docker &>/dev/null; then
    if docker info &>/dev/null 2>&1; then
      echo "✅ Running"
    else
      echo "⭕ Installed (not running)"
    fi
  else
    echo "❌ Not installed"
  fi
}

check_webui() {
  if curl -s --max-time 1 http://localhost:8080 &>/dev/null; then
    echo "✅ http://localhost:8080"
  else
    echo "⭕ Not running"
  fi
}

# ── Display ───────────────────────────────────────────────────
echo ""
if [ "$LANG_AR" = true ]; then
  echo -e "${BLUE}${BOLD}╔══════════════════════════════════════════════════╗${NC}"
  echo -e "${BLUE}${BOLD}║         لوحة حالة النظام — Y7 OS                  ║${NC}"
  echo -e "${BLUE}${BOLD}╠══════════════════════════════════════════════════╣${NC}"
else
  echo -e "${BLUE}${BOLD}╔══════════════════════════════════════════════════╗${NC}"
  echo -e "${BLUE}${BOLD}║              Y7 OS System Status                 ║${NC}"
  echo -e "${BLUE}${BOLD}╠══════════════════════════════════════════════════╣${NC}"
fi

printf "${BLUE}${BOLD}║${NC} %-8s %3d%%  $(bar $ram_pct)  %5d/%5dMB ${BLUE}${BOLD}║${NC}\n" "RAM:" $ram_pct $ram_used $ram_total
printf "${BLUE}${BOLD}║${NC} %-8s %3d%%  $(bar $cpu_pct)  %d cores       ${BLUE}${BOLD}║${NC}\n" "CPU:" $cpu_pct $cpu_cores
printf "${BLUE}${BOLD}║${NC} %-8s %3d%%  $(bar $disk_pct)  %4d/%4dGB   ${BLUE}${BOLD}║${NC}\n" "Disk:" $disk_pct $((disk_total - disk_free)) $disk_total

echo -e "${BLUE}${BOLD}╠══════════════════════════════════════════════════╣${NC}"
printf "${BLUE}${BOLD}║${NC} %-8s %s ${BLUE}${BOLD}║${NC}\n" "Uptime:" "$uptime_str"

echo -e "${BLUE}${BOLD}╠══════════════════════════════════════════════════╣${NC}"
printf "${BLUE}${BOLD}║${NC} %-8s %-38s ${BLUE}${BOLD}║${NC}\n" "Ollama:" "$(check_ollama)"
printf "${BLUE}${BOLD}║${NC} %-8s %-38s ${BLUE}${BOLD}║${NC}\n" "Docker:" "$(check_docker)"
printf "${BLUE}${BOLD}║${NC} %-8s %-38s ${BLUE}${BOLD}║${NC}\n" "WebUI:" "$(check_webui)"

echo -e "${BLUE}${BOLD}╚══════════════════════════════════════════════════╝${NC}"
echo ""

# ── Quick Actions ─────────────────────────────────────────────
if [ "$LANG_AR" = true ]; then
  echo -e "  ${BOLD}الأوامر السريعة:${NC}"
  echo -e "    ${CYAN}y7-ai${NC}           بدء المحادثة"
  echo -e "    ${CYAN}y7-models list${NC}  عرض النماذج"
else
  echo -e "  ${BOLD}Quick commands:${NC}"
  echo -e "    ${CYAN}y7-ai${NC}               Start AI chat"
  echo -e "    ${CYAN}y7-models list${NC}      List downloaded models"
  echo -e "    ${CYAN}y7-models recommend${NC} Best model for your RAM"
fi
echo ""
