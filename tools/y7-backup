#!/bin/bash
set -e

VERSION="1.0.0"
LANG="${Y7_LANG:-en}"
BACKUP_DIR="${Y7_BACKUP_DIR:-$HOME/y7os-backups}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

msg() { echo -e "${GREEN}[y7-backup]${NC} $1"; }
warn() { echo -e "${YELLOW}[warning]${NC} $1"; }
error() { echo -e "${RED}[error]${NC} $1"; exit 1; }

show_help() {
    if [ "$LANG" = "ar" ]; then
        cat << 'EOF'
y7-backup — نسخ احتياطي لبيانات Y7 OS

الاستخدام:
  y7-backup [أمر] [خيارات]

الأوامر:
  create      إنشاء نسخة احتياطية
  restore     استعادة من نسخة احتياطية
  list        عرض النسخ الاحتياطية
  delete      حذف نسخة احتياطية
  export      تصدير النماذج
  import      استيراد النماذج

خيارات:
  --models    تضمين نماذج Ollama
  --config    تضمين الإعدادات فقط
  --output    مسار الإخراج
  --help      عرض المساعدة
EOF
    else
        cat << 'EOF'
y7-backup — Backup Y7 OS data

Usage:
  y7-backup [command] [options]

Commands:
  create      Create a backup
  restore     Restore from backup
  list        List backups
  delete      Delete a backup
  export      Export models to file
  import      Import models from file

Options:
  --models    Include Ollama models (large!)
  --config    Config only (small)
  --output    Output path
  --help      Show this help

Examples:
  y7-backup create
  y7-backup create --models
  y7-backup restore y7os-backup-20260512.tar.gz
  y7-backup list
EOF
    fi
}

create_backup() {
    local INCLUDE_MODELS=false
    local OUTPUT=""

    # Parse args
    while [[ $# -gt 0 ]]; do
        case $1 in
            --models) INCLUDE_MODELS=true; shift ;;
            --output) OUTPUT="$2"; shift 2 ;;
            --config) shift ;;
            *) shift ;;
        esac
    done

    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    BACKUP_NAME="y7os-backup-$TIMESTAMP"

    if [ -n "$OUTPUT" ]; then
        BACKUP_PATH="$OUTPUT"
    else
        mkdir -p "$BACKUP_DIR"
        BACKUP_PATH="$BACKUP_DIR/$BACKUP_NAME.tar.gz"
    fi

    msg "Creating backup: $BACKUP_NAME"

    # Create temp directory
    TEMP_DIR=$(mktemp -d)
    mkdir -p "$TEMP_DIR/$BACKUP_NAME"

    # Backup configs
    msg "Backing up configurations..."
    mkdir -p "$TEMP_DIR/$BACKUP_NAME/config"

    [ -d "$HOME/.config/y7os" ] && cp -r "$HOME/.config/y7os" "$TEMP_DIR/$BACKUP_NAME/config/" 2>/dev/null || true
    [ -f "$HOME/.bashrc" ] && cp "$HOME/.bashrc" "$TEMP_DIR/$BACKUP_NAME/config/" 2>/dev/null || true

    # Backup model list
    msg "Backing up model list..."
    if command -v ollama &>/dev/null; then
        ollama list > "$TEMP_DIR/$BACKUP_NAME/models.txt" 2>/dev/null || true
    fi

    # Backup conversation history (if exists)
    if [ -d "$HOME/.y7os/history" ]; then
        msg "Backing up conversation history..."
        cp -r "$HOME/.y7os/history" "$TEMP_DIR/$BACKUP_NAME/" 2>/dev/null || true
    fi

    # Backup models (optional, large!)
    if [ "$INCLUDE_MODELS" = true ]; then
        msg "Backing up Ollama models (this may take a while)..."
        if [ -d "$HOME/.ollama/models" ]; then
            cp -r "$HOME/.ollama/models" "$TEMP_DIR/$BACKUP_NAME/" 2>/dev/null || warn "Could not backup models"
        fi
    fi

    # Create metadata
    cat > "$TEMP_DIR/$BACKUP_NAME/metadata.json" << EOF
{
    "version": "$VERSION",
    "timestamp": "$TIMESTAMP",
    "hostname": "$(hostname)",
    "includes_models": $INCLUDE_MODELS
}
EOF

    # Create archive
    msg "Compressing backup..."
    tar -czf "$BACKUP_PATH" -C "$TEMP_DIR" "$BACKUP_NAME"

    # Cleanup
    rm -rf "$TEMP_DIR"

    # Show result
    SIZE=$(du -h "$BACKUP_PATH" | cut -f1)
    msg "Backup created: $BACKUP_PATH ($SIZE)"
}

restore_backup() {
    local BACKUP_FILE="$1"

    if [ -z "$BACKUP_FILE" ]; then
        error "Usage: y7-backup restore <backup-file>"
    fi

    if [ ! -f "$BACKUP_FILE" ]; then
        # Check in backup dir
        if [ -f "$BACKUP_DIR/$BACKUP_FILE" ]; then
            BACKUP_FILE="$BACKUP_DIR/$BACKUP_FILE"
        else
            error "Backup file not found: $BACKUP_FILE"
        fi
    fi

    msg "Restoring from: $BACKUP_FILE"

    # Create temp directory
    TEMP_DIR=$(mktemp -d)

    # Extract
    tar -xzf "$BACKUP_FILE" -C "$TEMP_DIR"

    BACKUP_NAME=$(ls "$TEMP_DIR" | head -1)

    # Restore configs
    if [ -d "$TEMP_DIR/$BACKUP_NAME/config/y7os" ]; then
        msg "Restoring configurations..."
        mkdir -p "$HOME/.config"
        cp -r "$TEMP_DIR/$BACKUP_NAME/config/y7os" "$HOME/.config/" 2>/dev/null || true
    fi

    # Restore history
    if [ -d "$TEMP_DIR/$BACKUP_NAME/history" ]; then
        msg "Restoring conversation history..."
        mkdir -p "$HOME/.y7os"
        cp -r "$TEMP_DIR/$BACKUP_NAME/history" "$HOME/.y7os/" 2>/dev/null || true
    fi

    # Restore models
    if [ -d "$TEMP_DIR/$BACKUP_NAME/models" ]; then
        msg "Restoring Ollama models..."
        mkdir -p "$HOME/.ollama"
        cp -r "$TEMP_DIR/$BACKUP_NAME/models" "$HOME/.ollama/" 2>/dev/null || warn "Could not restore models"
    fi

    # Re-download models from list if not included
    if [ -f "$TEMP_DIR/$BACKUP_NAME/models.txt" ] && [ ! -d "$TEMP_DIR/$BACKUP_NAME/models" ]; then
        msg "Re-downloading models from backup list..."
        while read -r line; do
            MODEL=$(echo "$line" | awk '{print $1}')
            [ -n "$MODEL" ] && [ "$MODEL" != "NAME" ] && ollama pull "$MODEL" 2>/dev/null || true
        done < "$TEMP_DIR/$BACKUP_NAME/models.txt"
    fi

    # Cleanup
    rm -rf "$TEMP_DIR"

    msg "Restore complete!"
}

list_backups() {
    msg "Backups in $BACKUP_DIR:"
    echo ""

    if [ ! -d "$BACKUP_DIR" ]; then
        echo "  No backups found"
        return
    fi

    for backup in "$BACKUP_DIR"/*.tar.gz; do
        if [ -f "$backup" ]; then
            NAME=$(basename "$backup")
            SIZE=$(du -h "$backup" | cut -f1)
            DATE=$(stat -c %y "$backup" 2>/dev/null | cut -d' ' -f1 || stat -f %Sm "$backup" 2>/dev/null)
            echo "  $NAME ($SIZE) - $DATE"
        fi
    done
}

delete_backup() {
    local BACKUP_FILE="$1"

    if [ -z "$BACKUP_FILE" ]; then
        error "Usage: y7-backup delete <backup-name>"
    fi

    if [ ! -f "$BACKUP_DIR/$BACKUP_FILE" ]; then
        error "Backup not found: $BACKUP_FILE"
    fi

    rm -f "$BACKUP_DIR/$BACKUP_FILE"
    msg "Deleted: $BACKUP_FILE"
}

export_models() {
    local OUTPUT="${1:-$HOME/y7os-models-export.tar.gz}"

    msg "Exporting Ollama models to: $OUTPUT"

    if [ ! -d "$HOME/.ollama/models" ]; then
        error "No models found"
    fi

    tar -czf "$OUTPUT" -C "$HOME/.ollama" models

    SIZE=$(du -h "$OUTPUT" | cut -f1)
    msg "Export complete: $OUTPUT ($SIZE)"
}

import_models() {
    local INPUT="$1"

    if [ -z "$INPUT" ] || [ ! -f "$INPUT" ]; then
        error "Usage: y7-backup import <models-file.tar.gz>"
    fi

    msg "Importing models from: $INPUT"

    mkdir -p "$HOME/.ollama"
    tar -xzf "$INPUT" -C "$HOME/.ollama"

    msg "Import complete! Restart Ollama: sudo systemctl restart ollama"
}

# Main
case "${1:-}" in
    create)
        shift
        create_backup "$@"
        ;;
    restore)
        shift
        restore_backup "$@"
        ;;
    list)
        list_backups
        ;;
    delete)
        shift
        delete_backup "$@"
        ;;
    export)
        shift
        export_models "$@"
        ;;
    import)
        shift
        import_models "$@"
        ;;
    -h|--help|help)
        show_help
        ;;
    "")
        show_help
        ;;
    *)
        error "Unknown command: $1"
        ;;
esac
