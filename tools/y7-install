set -e

# ── Config ────────────────────────────────────────────────────
Y7_REPO="https://raw.githubusercontent.com/yahyasaqban-lab/y7os/main"
Y7_VERSION="0.1.0"

# ── Colors ────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Banner ────────────────────────────────────────────────────
print_banner() {
  echo ""
  echo -e "${BLUE}${BOLD}"
  echo "  ██╗   ██╗███████╗     ██████╗ ███████╗"
  echo "  ╚██╗ ██╔╝╚════██║    ██╔═══██╗██╔════╝"
  echo "   ╚████╔╝     ██╔╝    ██║   ██║███████╗"
  echo "    ╚██╔╝     ██╔╝     ██║   ██║╚════██║"
  echo "     ██║      ██║      ╚██████╔╝███████║"
  echo "     ╚═╝      ╚═╝       ╚═════╝ ╚══════╝"
  echo -e "${NC}"
  echo -e "${CYAN}  AI Stack Installer v${Y7_VERSION}${NC}"
  echo -e "${CYAN}  توزيعة لينكس مخصصة للذكاء الاصطناعي${NC}"
  echo ""
  echo -e "  ${BLUE}github.com/yahyasaqban-lab/y7os${NC}"
  echo "  ────────────────────────────────────────"
  echo ""
}

# ── Logging ───────────────────────────────────────────────────
log_ok()   { echo -e "  ${GREEN}✅${NC}  $1"; }
log_info() { echo -e "  ${CYAN}ℹ️ ${NC}  $1"; }
log_warn() { echo -e "  ${YELLOW}⚠️ ${NC}  $1"; }
log_err()  { echo -e "  ${RED}❌${NC}  $1"; }
log_step() { echo ""; echo -e "  ${BOLD}${BLUE}▶ $1${NC}"; echo ""; }

# ── Hardware Detection ────────────────────────────────────────
detect_hardware() {
  log_step "Detecting hardware..."

  ARCH=$(uname -m)
  log_info "Architecture: $ARCH"

  CPU_MODEL=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "Unknown")
  CPU_CORES=$(nproc)
  log_info "CPU: $CPU_MODEL ($CPU_CORES cores)"

  TOTAL_RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
  FREE_RAM_MB=$(free -m | awk '/^Mem:/{print $7}')
  log_info "RAM: ${TOTAL_RAM_MB}MB total, ${FREE_RAM_MB}MB available"

  FREE_DISK_GB=$(df -BG / | awk 'NR==2{print $4}' | tr -d 'G')
  log_info "Free disk: ${FREE_DISK_GB}GB"

  if grep -q avx2 /proc/cpuinfo 2>/dev/null; then
    AVX2_SUPPORT=true
    log_info "AVX2: ✅ Supported"
  else
    AVX2_SUPPORT=false
    log_warn "AVX2: Not supported (will use generic build)"
  fi

  if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS_NAME="$NAME"
    OS_VERSION="$VERSION_ID"
    log_info "OS: $OS_NAME $OS_VERSION"
  else
    OS_NAME="Unknown"
  fi

  # Recommend model based on RAM
  if [ "$TOTAL_RAM_MB" -gt 12000 ]; then
    RECOMMENDED_MODEL="mistral:7b-q4_k_m"
    RECOMMENDED_LABEL="Mistral 7B Q4"
  elif [ "$TOTAL_RAM_MB" -gt 5000 ]; then
    RECOMMENDED_MODEL="phi3:mini"
    RECOMMENDED_LABEL="Phi-3 Mini"
  elif [ "$TOTAL_RAM_MB" -gt 3000 ]; then
    RECOMMENDED_MODEL="gemma:2b"
    RECOMMENDED_LABEL="Gemma 2B"
  else
    RECOMMENDED_MODEL="tinyllama"
    RECOMMENDED_LABEL="TinyLlama"
  fi

  log_info "Recommended model: $RECOMMENDED_LABEL"
}

# ── Preflight Checks ──────────────────────────────────────────
preflight_checks() {
  log_step "Running preflight checks..."

  if [ "$(uname)" != "Linux" ]; then
    log_err "Y7 OS requires Linux."
    exit 1
  fi

  if [ "$EUID" -eq 0 ]; then
    log_warn "Running as root — not recommended but allowed."
  fi

  if [ "$TOTAL_RAM_MB" -lt 2000 ]; then
    log_err "Y7 OS requires at least 2GB RAM. Found: ${TOTAL_RAM_MB}MB"
    exit 1
  fi

  if [ "$FREE_DISK_GB" -lt 5 ]; then
    log_err "Y7 OS requires at least 5GB free disk. Found: ${FREE_DISK_GB}GB"
    exit 1
  fi

  if curl -s --max-time 5 https://ollama.ai > /dev/null 2>&1; then
    log_ok "Internet connection: OK"
  else
    log_warn "No internet — some components may fail to install."
  fi

  if command -v apt &>/dev/null; then
    PKG_MANAGER="apt"
    log_ok "Package manager: apt (Debian/Ubuntu)"
  elif command -v dnf &>/dev/null; then
    PKG_MANAGER="dnf"
    log_ok "Package manager: dnf (Fedora/RHEL)"
  elif command -v pacman &>/dev/null; then
    PKG_MANAGER="pacman"
    log_ok "Package manager: pacman (Arch)"
  else
    log_err "Unsupported package manager. Y7 OS supports apt, dnf, pacman."
    exit 1
  fi

  log_ok "All preflight checks passed"
}

# ── Install Dependencies ──────────────────────────────────────
install_dependencies() {
  log_step "Installing dependencies..."

  DEPS="curl wget git"

  case "$PKG_MANAGER" in
    apt)
      sudo apt-get update -qq
      sudo apt-get install -y $DEPS
      ;;
    dnf)
      sudo dnf install -y $DEPS
      ;;
    pacman)
      sudo pacman -Sy --noconfirm $DEPS
      ;;
  esac

  log_ok "Dependencies installed"
}

# ── ZRAM Setup ────────────────────────────────────────────────
setup_zram() {
  log_step "Configuring ZRAM (compressed swap)..."

  ZRAM_SIZE_MB=$((TOTAL_RAM_MB / 2))
  ZRAM_SIZE="${ZRAM_SIZE_MB}M"

  if ! lsmod | grep -q zram; then
    sudo modprobe zram 2>/dev/null || { log_warn "ZRAM module not available"; return; }
  fi

  if [ -f /sys/block/zram0/comp_algorithm ]; then
    echo lz4 | sudo tee /sys/block/zram0/comp_algorithm > /dev/null 2>&1 || true
    echo "$ZRAM_SIZE" | sudo tee /sys/block/zram0/disksize > /dev/null 2>&1 || true
    sudo mkswap /dev/zram0 > /dev/null 2>&1 || true
    sudo swapon -p 100 /dev/zram0 > /dev/null 2>&1 || true
    log_ok "ZRAM: ${ZRAM_SIZE} compressed swap (lz4)"
  else
    log_warn "ZRAM device not found, skipping"
  fi
}

# ── Install Ollama ────────────────────────────────────────────
install_ollama() {
  log_step "Installing Ollama..."

  if command -v ollama &>/dev/null; then
    log_info "Ollama already installed: $(ollama --version 2>/dev/null || echo 'unknown')"
    return
  fi

  curl -fsSL https://ollama.ai/install.sh | sh

  if [ ! -f /etc/systemd/system/ollama.service.d/y7.conf ]; then
    sudo mkdir -p /etc/systemd/system/ollama.service.d/
    cat << EOF | sudo tee /etc/systemd/system/ollama.service.d/y7.conf > /dev/null
[Service]
Environment="OLLAMA_HOST=0.0.0.0:11434"
Environment="OLLAMA_NUM_PARALLEL=1"
Environment="OLLAMA_MAX_LOADED_MODELS=1"
Environment="OLLAMA_KEEP_ALIVE=5m"
EOF
    sudo systemctl daemon-reload 2>/dev/null || true
    sudo systemctl restart ollama 2>/dev/null || true
  fi

  log_ok "Ollama installed"
}

# ── Install Docker ────────────────────────────────────────────
install_docker() {
  log_step "Checking Docker..."

  if command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
    log_ok "Docker already running"
    return
  fi

  log_info "Installing Docker..."

  case "$PKG_MANAGER" in
    apt)
      sudo apt-get install -y docker.io 2>/dev/null && \
        { sudo systemctl enable docker; sudo systemctl start docker; } && \
        log_ok "Docker installed" || \
        log_warn "Could not install Docker — install manually"
      ;;
    dnf)
      sudo dnf install -y docker && sudo systemctl enable --now docker
      log_ok "Docker installed"
      ;;
    pacman)
      sudo pacman -Sy --noconfirm docker && sudo systemctl enable --now docker
      log_ok "Docker installed"
      ;;
  esac

  if command -v docker &>/dev/null; then
    sudo usermod -aG docker "$USER" 2>/dev/null || true
  fi
}

# ── Create AI Directory ───────────────────────────────────────
create_ai_structure() {
  log_step "Creating /ai/ directory..."

  sudo mkdir -p /ai/{models,prompts,outputs,logs}
  sudo chown -R $USER:$USER /ai/ 2>/dev/null || sudo chmod -R 777 /ai/

  cat << 'EOF' > /ai/prompts/default-ar.txt
أنت مساعد ذكاء اصطناعي مفيد. أجب بالعربية بشكل واضح وموجز.
EOF

  cat << 'EOF' > /ai/prompts/default-en.txt
You are a helpful AI assistant. Answer clearly and concisely.
EOF

  log_ok "Created /ai/ structure"
}

# ── Install Y7 Tools ──────────────────────────────────────────
install_y7_tools() {
  log_step "Installing Y7 OS tools..."

  sudo mkdir -p /usr/local/bin

  for tool in y7-ai y7-models y7-status; do
    log_info "Installing $tool..."
    if curl -fsSL "${Y7_REPO}/tools/${tool}" -o "/tmp/${tool}"; then
      sudo mv "/tmp/${tool}" "/usr/local/bin/${tool}"
      sudo chmod +x "/usr/local/bin/${tool}"
    else
      log_warn "Could not download $tool"
    fi
  done

  log_ok "Y7 tools installed: y7-ai, y7-models, y7-status"
}

# ── Download Model ────────────────────────────────────────────
download_starter_model() {
  log_step "Downloading starter model: $RECOMMENDED_LABEL..."
  log_info "This may take a few minutes..."

  ollama serve &>/dev/null &
  local waited=0
  while ! curl -s http://localhost:11434 &>/dev/null; do
    sleep 1; waited=$((waited+1))
    [ $waited -gt 15 ] && break
  done

  if ollama pull "$RECOMMENDED_MODEL"; then
    log_ok "Model ready: $RECOMMENDED_MODEL"
  else
    log_warn "Could not download $RECOMMENDED_MODEL"
    log_info "Run manually: ollama pull $RECOMMENDED_MODEL"
  fi
}

# ── Install WebUI ─────────────────────────────────────────────
install_webui() {
  log_step "Setting up Open WebUI..."

  sudo systemctl start docker 2>/dev/null || true
  sleep 2

  if command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
    docker rm -f y7-webui 2>/dev/null || true

    docker run -d \
      -p 8080:8080 \
      -v /ai/webui:/app/backend/data \
      -e OLLAMA_BASE_URL=http://host.docker.internal:11434 \
      --add-host=host.docker.internal:host-gateway \
      --name y7-webui \
      --restart unless-stopped \
      ghcr.io/open-webui/open-webui:main 2>/dev/null && \
      log_ok "Open WebUI: http://localhost:8080" || \
      log_warn "WebUI failed — run: docker pull ghcr.io/open-webui/open-webui:main"
  else
    log_warn "Docker unavailable — WebUI skipped"
  fi
}

# ── Summary ───────────────────────────────────────────────────
print_summary() {
  echo ""
  echo -e "${BLUE}${BOLD}  ════════════════════════════════════════${NC}"
  echo -e "${GREEN}${BOLD}  🎉 Y7 OS Installation Complete!${NC}"
  echo -e "${BLUE}${BOLD}  ════════════════════════════════════════${NC}"
  echo ""
  log_ok "AI model: $RECOMMENDED_MODEL"
  log_ok "Tools: y7-ai, y7-models, y7-status"
  log_ok "Models: /ai/models"
  echo ""
  echo -e "  ${BOLD}Quick Start:${NC}"
  echo -e "    ${CYAN}y7-ai${NC}               Start AI chat"
  echo -e "    ${CYAN}y7-status${NC}           System dashboard"
  echo -e "    ${CYAN}y7-models recommend${NC} Best model for your RAM"
  echo ""
  echo -e "  ${BOLD}WebUI:${NC} http://localhost:8080"
  echo -e "  ${BOLD}GitHub:${NC} github.com/yahyasaqban-lab/y7os"
  echo ""
}

# ── Main ──────────────────────────────────────────────────────
main() {
  print_banner
  detect_hardware
  preflight_checks
  install_dependencies
  setup_zram
  install_docker
  install_ollama
  create_ai_structure
  install_y7_tools
  download_starter_model
  install_webui
  print_summary
}

main "$@"
