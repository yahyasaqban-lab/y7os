################################################################################
# Main Installation Flow
################################################################################

main() {
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_usage
                exit 0
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -d|--dry-run)
                DRY_RUN=true
                shift
                ;;
            -s|--skip-validation)
                SKIP_VALIDATION=true
                shift
                ;;
            --lang)
                LANG_MODE="$2"
                shift 2
                ;;
            --backend)
                AI_BACKEND="$2"
                shift 2
                ;;
            *)
                msg_error "Unknown option: $1" "خيار غير معروف: $1"
                show_usage
                exit 1
                ;;
        esac
    done
    
    # Initialize log file
    mkdir -p "$(dirname "$LOG_FILE")"
    touch "$LOG_FILE"
    log "=== Y7 OS Installation Started (v${VERSION}) ==="
    log "Language: $LANG_MODE | Backend: $AI_BACKEND | Verbose: $VERBOSE | DryRun: $DRY_RUN"
    
    # Run installation phases
    preflight_checks
    select_ai_backend
    
    msg_title "=== STARTING INSTALLATION ===" "=== بدء التثبيت ==="
    
    install_base_packages
    install_python
    install_docker
    install_git
    
    configure_zram
    
    install_ai_stack
    install_y7_tools
    
    validate_installation
    
    # Print summary
    if [[ "$LANG_MODE" == "ar" ]]; then
        print_summary_ar
    else
        print_summary
    fi
    
    log "=== Y7 OS Installation Completed Successfully ==="
}

# Run main if script is executed (not sourced)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
