#!/bin/bash

################################################################################
# Y7 OS — AI-First Linux Distribution Installer
# 
# The AI-first Linux distro for low-resource hardware.
# Arabic & English. Privacy-first. One command to install.
#
# https://github.com/yahyasaqban-lab/y7os
################################################################################

set -euo pipefail

################################################################################
# Configuration & Globals
################################################################################

readonly VERSION="0.1.0"
readonly SCRIPT_NAME="y7-install"
readonly LOG_FILE="/var/log/y7-install.log"
readonly BACKUP_DIR="/opt/y7-backups"
readonly Y7_HOME="/opt/y7"
readonly Y7_MODELS_DIR="${Y7_HOME}/models"
readonly Y7_CONFIG_DIR="/etc/y7"

# Color codes for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly NC='\033[0m' # No Color

# Language setting (detect or default to English)
LANG_MODE="${LANG_MODE:-en}"
if [[ "${LANG:-}" == *"ar"* ]] || [[ "${LC_ALL:-}" == *"ar"* ]]; then
    LANG_MODE="ar"
fi

# Hardware detection
DETECTED_OS=""
DETECTED_ARCH=""
DETECTED_RAM_GB=0
DETECTED_CPU_CORES=0
DETECTED_DEVICE_TYPE=""
DETECTED_GPU=""
HAS_DOCKER=false
HAS_PYTHON=false
AI_BACKEND="ollama"  # Default, may be overridden

# Installation flags
SKIP_VALIDATION=false
VERBOSE=false
DRY_RUN=false

################################################################################
# Bilingual String Functions
################################################################################

msg_title() {
    local title_en="$1"
    local title_ar="$2"
    
    if [[ "$LANG_MODE" == "ar" ]]; then
        echo -e "${BLUE}${title_ar}${NC}"
    else
        echo -e "${BLUE}${title_en}${NC}"
    fi
}

msg_success() {
    local msg_en="$1"
    local msg_ar="$2"
    
    if [[ "$LANG_MODE" == "ar" ]]; then
        echo -e "${GREEN}✓ ${msg_ar}${NC}"
    else
        echo -e "${GREEN}✓ ${msg_en}${NC}"
    fi
}

msg_error() {
    local msg_en="$1"
    local msg_ar="$2"
    
    if [[ "$LANG_MODE" == "ar" ]]; then
        echo -e "${RED}✗ ${msg_ar}${NC}" >&2
    else
        echo -e "${RED}✗ ${msg_en}${NC}" >&2
    fi
}

msg_warn() {
    local msg_en="$1"
    local msg_ar="$2"
    
    if [[ "$LANG_MODE" == "ar" ]]; then
        echo -e "${YELLOW}⚠ ${msg_ar}${NC}"
    else
        echo -e "${YELLOW}⚠ ${msg_en}${NC}"
    fi
}

msg_info() {
    local msg_en="$1"
    local msg_ar="$2"
    
    if [[ "$LANG_MODE" == "ar" ]]; then
        echo -e "${CYAN}ℹ ${msg_ar}${NC}"
    else
        echo -e "${CYAN}ℹ ${msg_en}${NC}"
    fi
}

################################################################################
# Logging & Error Handling
################################################################################

log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

run_cmd() {
    local cmd="$@"
    if [[ "$VERBOSE" == "true" ]]; then
        msg_info "Running: $cmd" "تشغيل: $cmd"
    fi
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "[DRY RUN] $cmd"
        return 0
    fi
    
    log "EXECUTE: $cmd"
    if eval "$cmd" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        log "FAILED: $cmd"
        return 1
    fi
}

trap_exit() {
    local exit_code=$?
    
    if [[ $exit_code -ne 0 ]]; then
        msg_error \
            "Installation failed. Check $LOG_FILE for details." \
            "فشل التثبيت. تحقق من $LOG_FILE للمزيد من التفاصيل."
        log "EXIT CODE: $exit_code"
    fi
    
    exit "$exit_code"
}

trap trap_exit EXIT

################################################################################
# Usage & Help
################################################################################

show_usage() {
    cat <<EOF
${BLUE}Y7 OS Installer v${VERSION}${NC}

USAGE:
    sudo $SCRIPT_NAME [OPTIONS]

OPTIONS:
    -h, --help              Show this help message
    -v, --verbose           Enable verbose output
    -d, --dry-run           Simulate installation without making changes
    -s, --skip-validation   Skip component validation after install
    --lang en|ar            Set language (en=English, ar=Arabic)
    --backend ollama|llama  Choose AI backend (default: ollama)

EXAMPLES:
    sudo $SCRIPT_NAME                    # Standard installation (English)
    sudo $SCRIPT_NAME --lang ar          # Installation in Arabic
    sudo $SCRIPT_NAME --backend llama    # Use llama.cpp instead of Ollama
    sudo $SCRIPT_NAME --dry-run --verbose  # Simulate with verbose output

REQUIREMENTS:
    - Root/sudo access
    - Ubuntu 20.04+ / Debian 11+ / CentOS 8+ / Raspberry Pi OS
    - Minimum 4GB RAM (8GB+ recommended)
    - At least 20GB free disk space
    - Stable internet connection

For more info: https://github.com/yahyasaqban-lab/y7os
EOF
}

################################################################################
# Pre-flight Checks
################################################################################

check_root() {
    if [[ $EUID -ne 0 ]]; then
        msg_error \
            "This script must be run as root. Use: sudo $SCRIPT_NAME" \
            "يجب تشغيل هذا السكريبت كـ root. استخدم: sudo $SCRIPT_NAME"
        exit 1
    fi
}

detect_os() {
    msg_title "Detecting Operating System" "كشف نظام التشغيل"
    
    if [[ -f /etc/os-release ]]; then
        . /etc/os-release
        DETECTED_OS="$ID"
        log "Detected OS: $ID ($PRETTY_NAME)"
        msg_success "OS detected: $PRETTY_NAME" "تم كشف نظام التشغيل: $PRETTY_NAME"
    else
        msg_error "Cannot detect OS" "لا يمكن كشف نظام التشغيل"
        exit 1
    fi
}

detect_arch() {
    msg_title "Detecting Architecture" "كشف المعمارية"
    
    DETECTED_ARCH=$(uname -m)
    log "Detected architecture: $DETECTED_ARCH"
    msg_success "Architecture: $DETECTED_ARCH" "المعمارية: $DETECTED_ARCH"
}

detect_hardware() {
    msg_title "Detecting Hardware" "كشف الأجهزة"
    
    # RAM detection
    DETECTED_RAM_GB=$(free -g | awk 'NR==2 {print $2}')
    msg_info "Available RAM: ${DETECTED_RAM_GB}GB" "الذاكرة المتاحة: ${DETECTED_RAM_GB}GB"
    
    # CPU detection
    DETECTED_CPU_CORES=$(nproc)
    msg_info "CPU cores: $DETECTED_CPU_CORES" "معالجات: $DETECTED_CPU_CORES"
    
    # Device type detection
    if grep -q "BCM2835\|Raspberry" /proc/cpuinfo 2>/dev/null; then
        DETECTED_DEVICE_TYPE="raspberry_pi"
        msg_info "Device: Raspberry Pi" "الجهاز: Raspberry Pi"
    elif lspci 2>/dev/null | grep -q "VGA\|3D"; then
        DETECTED_DEVICE_TYPE="laptop_with_gpu"
        msg_info "Device: Laptop with GPU" "الجهاز: لابتوب مع كارت شاشة"
    else
        DETECTED_DEVICE_TYPE="generic"
        msg_info "Device: Generic/Server" "الجهاز: خادم عام"
    fi
    
    # GPU detection
    if command -v nvidia-smi &> /dev/null; then
        DETECTED_GPU="nvidia"
        msg_success "NVIDIA GPU detected" "تم كشف NVIDIA GPU"
    elif command -v rocm-smi &> /dev/null; then
        DETECTED_GPU="amd"
        msg_success "AMD GPU detected" "تم كشف AMD GPU"
    fi
    
    log "Hardware: Device=$DETECTED_DEVICE_TYPE, GPU=$DETECTED_GPU, Cores=$DETECTED_CPU_CORES, RAM=${DETECTED_RAM_GB}GB"
}

check_disk_space() {
    msg_title "Checking Disk Space" "فحص مساحة القرص"
    
    local required_gb=20
    local available_gb=$(df / | awk 'NR==2 {print int($4/1048576)}')
    
    msg_info "Required: ${required_gb}GB, Available: ${available_gb}GB" \
             "مطلوب: ${required_gb}GB، المتاح: ${available_gb}GB"
    
    if [[ $available_gb -lt $required_gb ]]; then
        msg_error \
            "Insufficient disk space. Need at least ${required_gb}GB" \
            "مساحة قرص غير كافية. تحتاج إلى ${required_gb}GB على الأقل"
        exit 1
    fi
    
    msg_success "Disk space OK" "مساحة القرص كافية"
}

check_internet() {
    msg_title "Checking Internet Connectivity" "فحص الاتصال بالإنترنت"
    
    if ping -c 1 8.8.8.8 &> /dev/null || ping -c 1 1.1.1.1 &> /dev/null; then
        msg_success "Internet connectivity OK" "الاتصال بالإنترنت يعمل"
    else
        msg_warn \
            "Cannot reach internet. Installation may fail." \
            "لا يمكن الوصول إلى الإنترنت. قد يفشل التثبيت."
    fi
}

preflight_checks() {
    msg_title "=== PRE-FLIGHT CHECKS ===" "=== الفحوصات الأولية ==="
    
    check_root
    detect_os
    detect_arch
    detect_hardware
    check_disk_space
    check_internet
    
    msg_success "All pre-flight checks passed" "اجتياز جميع الفحوصات الأولية"
}

################################################################################
# AI Backend Selection
################################################################################

select_ai_backend() {
    msg_title "Selecting AI Backend" "اختيار محرك الذكاء الاصطناعي"
    
    # Auto-select based on hardware
    if [[ $DETECTED_RAM_GB -lt 4 ]] || [[ "$DETECTED_DEVICE_TYPE" == "raspberry_pi" ]]; then
        AI_BACKEND="llama"
        msg_info "Low-resource device detected. Using llama.cpp" \
                 "تم كشف جهاز محدود الموارد. استخدام llama.cpp"
    else
        AI_BACKEND="ollama"
        msg_info "Using Ollama (higher resource requirement)" \
                 "استخدام Ollama (يتطلب موارد أكثر)"
    fi
    
    log "Selected AI backend: $AI_BACKEND"
}

################################################################################
# System Package Installation
################################################################################

install_base_packages() {
    msg_title "Installing Base Packages" "تثبيت الحزم الأساسية"
    
    run_cmd "apt-get update"
    
    local packages=(
        "curl"
        "wget"
        "git"
        "build-essential"
        "libssl-dev"
        "libffi-dev"
        "python3-dev"
        "python3-pip"
        "python3-venv"
        "zram-tools"
        "htop"
        "tmux"
        "nano"
        "vim"
        "jq"
    )
    
    msg_info "Installing: ${packages[*]}" "تثبيت: ${packages[*]}"
    run_cmd "apt-get install -y ${packages[*]}"
    
    msg_success "Base packages installed" "تم تثبيت الحزم الأساسية"
}

install_python() {
    msg_title "Installing Python 3.11+" "تثبيت Python 3.11+"
    
    run_cmd "apt-get install -y python3 python3-pip python3-venv"
    
    local python_version=$(python3 --version 2>&1 | awk '{print $2}')
    msg_success "Python $python_version installed" "تم تثبيت Python $python_version"
    
    # Upgrade pip
    run_cmd "python3 -m pip install --upgrade pip setuptools wheel"
}

install_docker() {
    msg_title "Installing Docker & Docker Compose" "تثبيت Docker"
    
    if command -v docker &> /dev/null; then
        msg_warn "Docker already installed" "Docker مثبت بالفعل"
        return
    fi
    
    # Install Docker from official repository
    run_cmd "apt-get install -y docker.io docker-compose"
    
    # Enable Docker daemon
    run_cmd "systemctl enable docker"
    run_cmd "systemctl start docker"
    
    # Add user to docker group (optional, commented for security)
    # run_cmd "usermod -aG docker $SUDO_USER"
    
    HAS_DOCKER=true
    msg_success "Docker installed" "تم تثبيت Docker"
}

install_git() {
    msg_title "Installing Git Configuration" "تثبيت Git"
    
    if command -v git &> /dev/null; then
        msg_success "Git already installed" "Git مثبت بالفعل"
        return
    fi
    
    run_cmd "apt-get install -y git"
}

################################################################################
# AI Stack Installation
################################################################################

install_ollama() {
    msg_title "Installing Ollama" "تثبيت Ollama"
    
    if command -v ollama &> /dev/null; then
        msg_warn "Ollama already installed" "Ollama مثبت بالفعل"
        return
    fi
    
    msg_info "Downloading Ollama..." "جاري تحميل Ollama..."
    run_cmd "curl -fsSL https://ollama.ai/install.sh | sh"
    
    # Create ollama user if it doesn't exist
    if ! id -u ollama &>/dev/null 2>&1; then
        run_cmd "useradd -r -s /bin/false ollama"
    fi
    
    run_cmd "systemctl enable ollama"
    run_cmd "systemctl start ollama"
    
    sleep 3
    msg_success "Ollama installed and running" "تم تثبيت Ollama وتشغيله"
}

install_llama_cpp() {
    msg_title "Installing llama.cpp" "تثبيت llama.cpp"
    
    if [[ -d "/opt/llama.cpp" ]]; then
        msg_warn "llama.cpp already installed" "llama.cpp مثبت بالفعل"
        return
    fi
    
    msg_info "Cloning llama.cpp repository..." "جاري نسخ مستودع llama.cpp..."
    run_cmd "git clone https://github.com/ggerganov/llama.cpp.git /opt/llama.cpp"
    
    msg_info "Building llama.cpp..." "جاري بناء llama.cpp..."
    run_cmd "cd /opt/llama.cpp && make -j$DETECTED_CPU_CORES"
    
    run_cmd "chmod +x /opt/llama.cpp/main"
    
    msg_success "llama.cpp installed" "تم تثبيت llama.cpp"
}

install_open_webui() {
    msg_title "Installing Open WebUI" "تثبيت Open WebUI"
    
    msg_info "Installing via Docker..." "جاري التثبيت عبر Docker..."
    
    cat > /opt/y7/docker-compose.open-webui.yml <<'EOF'
version: '3.8'
services:
  open-webui:
    image: ghcr.io/open-webui/open-webui:latest
    container_name: open-webui
    ports:
      - "3000:8080"
    environment:
      - OLLAMA_API_BASE_URL=http://host.docker.internal:11434
    volumes:
      - open-webui-data:/app/backend/data
    restart: unless-stopped

volumes:
  open-webui-data:
EOF
    
    msg_success "Open WebUI Docker Compose created" "تم إنشاء Docker Compose لـ Open WebUI"
}

install_ai_stack() {
    msg_title "=== INSTALLING AI STACK ===" "=== تثبيت مكدس الذكاء الاصطناعي ==="
    
    if [[ "$AI_BACKEND" == "ollama" ]]; then
        install_ollama
    else
        install_llama_cpp
    fi
    
    install_open_webui
}

################################################################################
# Y7 OS Tools Installation
################################################################################

create_y7_directories() {
    msg_title "Creating Y7 Directories" "إنشاء مجلدات Y7"
    
    run_cmd "mkdir -p $Y7_HOME"
    run_cmd "mkdir -p $Y7_MODELS_DIR"
    run_cmd "mkdir -p $Y7_CONFIG_DIR"
    run_cmd "mkdir -p $BACKUP_DIR"
    
    run_cmd "chmod 755 $Y7_HOME"
    
    msg_success "Y7 directories created" "تم إنشاء مجلدات Y7"
}

install_y7_models_tool() {
    msg_title "Installing y7-models Tool" "تثبيت أداة y7-models"
    
    cat > /usr/local/bin/y7-models <<'TOOLS_EOF'
#!/bin/bash

# Y7 Models Manager
# Download, list, and manage quantized models for low-resource AI

MODELS_DIR="${Y7_MODELS_DIR:-/opt/y7/models}"

usage() {
    cat <<EOF
y7-models - Y7 AI Models Manager

USAGE:
    y7-models <command> [options]

COMMANDS:
    list            List available models
    download <id>   Download a model
    remove <id>     Remove a model
    info <id>       Show model details
    status          Show download status

MODELS:
    phi-3-mini      1.3B parameters, 1.2GB (Raspberry Pi)
    mistral-7b      7B quantized Q4, 4.2GB
    llama2-7b       7B quantized Q4, 4.2GB
    neural-chat-7b  7B optimized, 4.2GB

EXAMPLE:
    y7-models download phi-3-mini
EOF
}

case "${1:-help}" in
    list)
        echo "Available models:"
        echo "  - phi-3-mini (1.3B, 1.2GB)"
        echo "  - mistral-7b (7B Q4, 4.2GB)"
        echo "  - llama2-7b (7B Q4, 4.2GB)"
        echo "  - neural-chat-7b (7B, 4.2GB)"
        ;;
    download)
        if [[ -z "$2" ]]; then
            echo "Usage: y7-models download <model-id>"
            exit 1
        fi
        echo "Downloading model: $2"
        # Model download logic would go here
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
TOOLS_EOF
    
    run_cmd "chmod +x /usr/local/bin/y7-models"
    msg_success "y7-models tool installed" "تم تثبيت أداة y7-models"
}

install_y7_cli() {
    msg_title "Installing y7-cli" "تثبيت y7-cli"
    
    cat > /usr/local/bin/y7 <<'CLI_EOF'
#!/bin/bash

# Y7 CLI - Y7 OS Command Line Interface

VERSION="0.1.0"

usage() {
    cat <<EOF
y7 - Y7 OS Command Line Interface v${VERSION}

USAGE:
    y7 <command> [options]

COMMANDS:
    status          Show system status
    logs            View Y7 installation logs
    ai              Manage AI backend
    models          Manage AI models
    test            Run diagnostic tests
    help            Show this help message

EXAMPLES:
    y7 status
    y7 ai start
    y7 models list
    y7 test
EOF
}

case "${1:-help}" in
    status)
        echo "Y7 OS Status"
        echo "============"
        uname -a
        ;;
    logs)
        tail -f /var/log/y7-install.log
        ;;
    ai)
        echo "AI backend commands not yet implemented"
        ;;
    models)
        y7-models "$@"
        ;;
    test)
        echo "Running diagnostic tests..."
        # Test logic here
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
CLI_EOF
    
    run_cmd "chmod +x /usr/local/bin/y7"
    msg_success "y7-cli installed" "تم تثبيت y7-cli"
}

create_y7_config() {
    msg_title "Creating Y7 Configuration" "إنشاء إعدادات Y7"
    
    cat > $Y7_CONFIG_DIR/y7.conf <<EOF
# Y7 OS Configuration
# Generated by y7-install v${VERSION}

# AI Backend (ollama or llama)
AI_BACKEND=${AI_BACKEND}

# Installation Date
INSTALL_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')

# Detected Hardware
DEVICE_TYPE=${DETECTED_DEVICE_TYPE}
RAM_GB=${DETECTED_RAM_GB}
CPU_CORES=${DETECTED_CPU_CORES}
GPU=${DETECTED_GPU:-none}

# Paths
Y7_HOME=${Y7_HOME}
Y7_MODELS_DIR=${Y7_MODELS_DIR}

# Language
LANG_MODE=${LANG_MODE}
EOF
    
    msg_success "Configuration created at $Y7_CONFIG_DIR/y7.conf" \
                "تم إنشاء الإعدادات في $Y7_CONFIG_DIR/y7.conf"
}

install_y7_tools() {
    msg_title "=== INSTALLING Y7 TOOLS ===" "=== تثبيت أدوات Y7 ==="
    
    create_y7_directories
    install_y7_models_tool
    install_y7_cli
    create_y7_config
}

################################################################################
# ZRAM Configuration (for low-resource devices)
################################################################################

configure_zram() {
    msg_title "Configuring ZRAM (Swap Compression)" "تكوين ZRAM"
    
    if [[ $DETECTED_RAM_GB -lt 8 ]]; then
        msg_info "Enabling ZRAM for low-resource device" \
                 "تفعيل ZRAM للجهاز المحدود الموارد"
        
        run_cmd "modprobe zram"
        run_cmd "echo 2G > /sys/block/zram0/disksize"
        run_cmd "mkswap /dev/zram0"
        run_cmd "swapon /dev/zram0"
        
        msg_success "ZRAM configured (2GB)" "تم تكوين ZRAM (2GB)"
    fi
}

################################################################################
# Post-Installation Validation
################################################################################

validate_python() {
    msg_info "Validating Python..." "التحقق من Python..."
    
    if python3 -c "import sys; print(f'Python {sys.version}')" >> "$LOG_FILE" 2>&1; then
        msg_success "Python validation passed" "تم التحقق من Python بنجاح"
        return 0
    else
        msg_error "Python validation failed" "فشل التحقق من Python"
        return 1
    fi
}

validate_docker() {
    if [[ "$HAS_DOCKER" != "true" ]]; then
        return 0
    fi
    
    msg_info "Validating Docker..." "التحقق من Docker..."
    
    if docker --version >> "$LOG_FILE" 2>&1; then
        msg_success "Docker validation passed" "تم التحقق من Docker بنجاح"
        return 0
    else
        msg_error "Docker validation failed" "فشل التحقق من Docker"
        return 1
    fi
}

validate_ai_backend() {
    msg_info "Validating AI backend..." "التحقق من محرك الذكاء الاصطناعي..."
    
    if [[ "$AI_BACKEND" == "ollama" ]]; then
        if systemctl is-active --quiet ollama; then
            msg_success "Ollama is running" "Ollama قيد التشغيل"
            return 0
        else
            msg_warn "Ollama service not running. Starting..." \
                     "خدمة Ollama لا تعمل. جاري التشغيل..."
            systemctl start ollama
            sleep 2
            return 0
        fi
    elif [[ "$AI_BACKEND" == "llama" ]]; then
        if [[ -x /opt/llama.cpp/main ]]; then
            msg_success "llama.cpp binary found" "تم العثور على ملف llama.cpp"
            return 0
        else
            msg_error "llama.cpp binary not found" "لم يتم العثور على ملف llama.cpp"
            return 1
        fi
    fi
}

validate_y7_tools() {
    msg_info "Validating Y7 tools..." "التحقق من أدوات Y7..."
    
    local errors=0
    
    if command -v y7 &> /dev/null; then
        msg_success "y7-cli found" "تم العثور على y7-cli"
    else
        msg_error "y7-cli not found" "لم يتم العثور على y7-cli"
        ((errors++))
    fi
    
    if command -v y7-models &> /dev/null; then
        msg_success "y7-models found" "تم العثور على y7-models"
    else
        msg_error "y7-models not found" "لم يتم العثور على y7-models"
        ((errors++))
    fi
    
    return $errors
}

validate_installation() {
    msg_title "=== VALIDATING INSTALLATION ===" "=== التحقق من التثبيت ==="
    
    if [[ "$SKIP_VALIDATION" == "true" ]]; then
        msg_warn "Skipping validation" "تخطي التحقق"
        return
    fi
    
    local validation_errors=0
    
    validate_python || ((validation_errors++))
    validate_docker || ((validation_errors++))
    validate_ai_backend || ((validation_errors++))
    validate_y7_tools || ((validation_errors++))
    
    if [[ $validation_errors -eq 0 ]]; then
        msg_success "All validations passed!" "تم اجتياز جميع الفحوصات!"
    else
        msg_warn "$validation_errors validation(s) failed. Check logs." \
                 "فشل $validation_errors فحص(ات). تحقق من السجلات."
    fi
}

