#!/bin/bash
# y7-driver — GPU driver helper
set -e
R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; N='\033[0m'
msg(){ echo -e "${G}[y7-driver]${N} $1"; }
warn(){ echo -e "${Y}[y7-driver]${N} $1"; }
err(){ echo -e "${R}[y7-driver]${N} $1"; exit 1; }
[ $EUID -eq 0 ] || err "Need root"

case "${1:-status}" in
  status)
    echo "GPU: $(uname -m)"
    command -v nvidia-smi &>/dev/null && nvidia-smi --query-gpu=name,driver_version,memory.total --format=csv,noheader 2>/dev/null | head -1 && exit 0
    command -v rocm-smi &>/dev/null && rocm-smi --showproductname 2>/dev/null | head -3 && exit 0
    grep -qi "Apple" /proc/cpuinfo 2>/dev/null && echo "Apple Silicon (Metal GPU — Ollama native)" && exit 0
    lspci 2>/dev/null | grep -i "vga\|3d\|display" | head -3 || echo "No dedicated GPU detected"
    ;;
  install-nvidia)
    msg "Installing NVIDIA drivers..."
    apt-get install -y nvidia-driver-550 nvidia-utils-550 2>/dev/null || warn "Try: ubuntu-drivers autoinstall"
    msg "Reboot required"
    ;;
  install-amd)
    msg "Installing AMD ROCm..."
    apt-get install -y rocm-dkms rocm-libs 2>/dev/null || warn "See: https://rocm.docs.amd.com"
    ;;
  info)
    echo "Y7 OS supports: NVIDIA (CUDA), AMD (ROCm), Apple Silicon (Metal)"
    echo "NVIDIA: nvidia-smi | AMD: rocm-smi | Apple: uname -m = aarch64"
    ;;
  help|--help)
    echo "y7-driver {status|install-nvidia|install-amd|info}"
    ;;
esac
