#!/bin/bash
set -e

VERSION="1.0.0"
LANG="${Y7_LANG:-en}"
AGENTS_DIR="${Y7_AGENTS_DIR:-$HOME/.y7os/agents}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

msg() { echo -e "${GREEN}[y7-agents]${NC} $1"; }
warn() { echo -e "${YELLOW}[warning]${NC} $1"; }
error() { echo -e "${RED}[error]${NC} $1"; exit 1; }

show_help() {
    if [ "$LANG" = "ar" ]; then
        cat << 'EOF'
y7-agents — إدارة وكلاء الذكاء الاصطناعي

الاستخدام:
  y7-agents [أمر] [خيارات]

الأوامر:
  list        عرض الوكلاء المتاحين
  install     تثبيت وكيل
  remove      إزالة وكيل
  run         تشغيل وكيل
  update      تحديث وكيل
  status      حالة الوكلاء

الوكلاء المتاحين:
  zeus        إطار عمل الوكيل الشخصي (CLI, Telegram, Web)
  uta         وكيل البرمجة في الطرفية
  orphanim    وكيل أبحاث الأمان
  dragon      وكيل متعدد المهام
EOF
    else
        cat << 'EOF'
y7-agents — AI Agent Manager

Usage:
  y7-agents [command] [options]

Commands:
  list        List available agents
  install     Install an agent
  remove      Remove an agent
  run         Run an agent
  update      Update an agent
  status      Show agent status

Available Agents:
  zeus        Personal AI agent framework (CLI, Telegram, Web UI)
  uta         Terminal AI coding agent
  orphanim    Security research agent
  dragon      Multi-task autonomous agent

Examples:
  y7-agents list
  y7-agents install zeus
  y7-agents run uta "Create a Flask API"
  y7-agents run zeus chat "What's Bitcoin price?"
EOF
    fi
}

list_agents() {
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║                    Y7 OS AI Agents                           ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║                                                              ║"
    echo "║  ⚡ zeus      Personal AI Agent Framework                    ║"
    echo "║              CLI, Telegram bot, Web UI, REST API             ║"
    echo "║              Arabic support, multi-LLM (Ollama, DeepSeek)    ║"
    echo "║                                                              ║"
    echo "║  💻 uta       Terminal AI Coding Agent                       ║"
    echo "║              Like Claude Code, self-hosted                   ║"
    echo "║              File ops, code execution, web search            ║"
    echo "║                                                              ║"
    echo "║  🔒 orphanim  Security Research Agent                        ║"
    echo "║              Vulnerability discovery, reverse engineering    ║"
    echo "║              Fuzzing, exploit development                    ║"
    echo "║                                                              ║"
    echo "║  🐉 dragon    Multi-Task Autonomous Agent                    ║"
    echo "║              Parallel sub-agents, plan mode                  ║"
    echo "║              Web research, code execution                    ║"
    echo "║                                                              ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""

    echo "Installed:"
    for agent in zeus uta orphanim dragon; do
        if is_installed "$agent"; then
            echo -e "  ${GREEN}✓${NC} $agent"
        else
            echo -e "  ${RED}✗${NC} $agent"
        fi
    done
    echo ""
}

is_installed() {
    local AGENT="$1"
    case "$AGENT" in
        zeus)
            [ -d "$AGENTS_DIR/0xzeus" ] && return 0
            ;;
        uta)
            [ -f "$AGENTS_DIR/uta/uta.py" ] && return 0
            ;;
        orphanim)
            [ -f "$AGENTS_DIR/orphanim/orphanim.py" ] && return 0
            ;;
        dragon)
            [ -f "$AGENTS_DIR/dragon/dragon_agent.py" ] && return 0
            ;;
    esac
    return 1
}

install_zeus() {
    msg "Installing 0xZeus..."

    mkdir -p "$AGENTS_DIR"
    cd "$AGENTS_DIR"

    if [ -d "0xzeus" ]; then
        warn "Zeus already installed, updating..."
        cd 0xzeus && git pull
    else
        git clone https://github.com/yahyasaqban-lab/0xzeus.git
        cd 0xzeus
    fi

    # Create virtual environment
    python3 -m venv venv
    source venv/bin/activate

    # Install dependencies
    pip install -r requirements.txt 2>/dev/null || pip install requests rich prompt_toolkit

    deactivate

    # Create launcher script
    cat > /usr/local/bin/zeus << 'LAUNCHER'
#!/bin/bash
ZEUS_DIR="$HOME/.y7os/agents/0xzeus"
cd "$ZEUS_DIR"
source venv/bin/activate
python3 zeus "$@"
LAUNCHER
    chmod +x /usr/local/bin/zeus 2>/dev/null || sudo chmod +x /usr/local/bin/zeus

    msg "Zeus installed! Run: zeus chat \"Hello\""
}

install_uta() {
    msg "Installing Uta..."

    mkdir -p "$AGENTS_DIR/uta"
    cd "$AGENTS_DIR/uta"

    # Download single file
    curl -fsSL https://raw.githubusercontent.com/yahyasaqban-lab/uta/main/uta.py -o uta.py

    # Create launcher script
    cat > /usr/local/bin/uta << 'LAUNCHER'
#!/bin/bash
UTA_DIR="$HOME/.y7os/agents/uta"
python3 "$UTA_DIR/uta.py" "$@"
LAUNCHER
    chmod +x /usr/local/bin/uta 2>/dev/null || sudo chmod +x /usr/local/bin/uta

    msg "Uta installed! Run: uta \"Create a Python script\""
}

install_orphanim() {
    msg "Installing Orphanim..."

    mkdir -p "$AGENTS_DIR/orphanim"
    cd "$AGENTS_DIR/orphanim"

    # Download single file
    curl -fsSL https://raw.githubusercontent.com/yahyasaqban-lab/orphanim/main/orphanim.py -o orphanim.py

    # Create launcher script
    cat > /usr/local/bin/orphanim << 'LAUNCHER'
#!/bin/bash
ORPHANIM_DIR="$HOME/.y7os/agents/orphanim"
python3 "$ORPHANIM_DIR/orphanim.py" "$@"
LAUNCHER
    chmod +x /usr/local/bin/orphanim 2>/dev/null || sudo chmod +x /usr/local/bin/orphanim

    msg "Orphanim installed! Run: orphanim \"Analyze binary for vulnerabilities\""
}

install_dragon() {
    msg "Installing Dragon Agent..."

    mkdir -p "$AGENTS_DIR/dragon"
    cd "$AGENTS_DIR/dragon"

    # Download files
    curl -fsSL https://raw.githubusercontent.com/yahyasaqban-lab/dragon-agent/main/dragon_agent.py -o dragon_agent.py
    curl -fsSL https://raw.githubusercontent.com/yahyasaqban-lab/dragon-agent/main/dragon_agent_singlefile.py -o dragon_agent_singlefile.py 2>/dev/null || true

    # Create config directory
    mkdir -p config

    # Create launcher script
    cat > /usr/local/bin/dragon << 'LAUNCHER'
#!/bin/bash
DRAGON_DIR="$HOME/.y7os/agents/dragon"
python3 "$DRAGON_DIR/dragon_agent.py" "$@"
LAUNCHER
    chmod +x /usr/local/bin/dragon 2>/dev/null || sudo chmod +x /usr/local/bin/dragon

    msg "Dragon Agent installed! Run: dragon \"Research and create a report\""
}

install_agent() {
    local AGENT="$1"

    if [ -z "$AGENT" ]; then
        error "Usage: y7-agents install <agent-name>"
    fi

    case "$AGENT" in
        zeus|0xzeus)
            install_zeus
            ;;
        uta)
            install_uta
            ;;
        orphanim)
            install_orphanim
            ;;
        dragon|dragon-agent)
            install_dragon
            ;;
        all)
            install_zeus
            install_uta
            install_orphanim
            install_dragon
            msg "All agents installed!"
            ;;
        *)
            error "Unknown agent: $AGENT. Available: zeus, uta, orphanim, dragon, all"
            ;;
    esac
}

remove_agent() {
    local AGENT="$1"

    if [ -z "$AGENT" ]; then
        error "Usage: y7-agents remove <agent-name>"
    fi

    case "$AGENT" in
        zeus|0xzeus)
            rm -rf "$AGENTS_DIR/0xzeus"
            sudo rm -f /usr/local/bin/zeus 2>/dev/null || rm -f /usr/local/bin/zeus
            msg "Zeus removed"
            ;;
        uta)
            rm -rf "$AGENTS_DIR/uta"
            sudo rm -f /usr/local/bin/uta 2>/dev/null || rm -f /usr/local/bin/uta
            msg "Uta removed"
            ;;
        orphanim)
            rm -rf "$AGENTS_DIR/orphanim"
            sudo rm -f /usr/local/bin/orphanim 2>/dev/null || rm -f /usr/local/bin/orphanim
            msg "Orphanim removed"
            ;;
        dragon|dragon-agent)
            rm -rf "$AGENTS_DIR/dragon"
            sudo rm -f /usr/local/bin/dragon 2>/dev/null || rm -f /usr/local/bin/dragon
            msg "Dragon Agent removed"
            ;;
        all)
            rm -rf "$AGENTS_DIR"
            sudo rm -f /usr/local/bin/zeus /usr/local/bin/uta /usr/local/bin/orphanim /usr/local/bin/dragon 2>/dev/null || true
            msg "All agents removed"
            ;;
        *)
            error "Unknown agent: $AGENT"
            ;;
    esac
}

run_agent() {
    local AGENT="$1"
    shift

    if [ -z "$AGENT" ]; then
        error "Usage: y7-agents run <agent-name> [args]"
    fi

    case "$AGENT" in
        zeus|0xzeus)
            if ! is_installed zeus; then
                warn "Zeus not installed. Installing..."
                install_zeus
            fi
            zeus "$@"
            ;;
        uta)
            if ! is_installed uta; then
                warn "Uta not installed. Installing..."
                install_uta
            fi
            uta "$@"
            ;;
        orphanim)
            if ! is_installed orphanim; then
                warn "Orphanim not installed. Installing..."
                install_orphanim
            fi
            orphanim "$@"
            ;;
        dragon|dragon-agent)
            if ! is_installed dragon; then
                warn "Dragon not installed. Installing..."
                install_dragon
            fi
            dragon "$@"
            ;;
        *)
            error "Unknown agent: $AGENT"
            ;;
    esac
}

update_agent() {
    local AGENT="$1"

    if [ -z "$AGENT" ]; then
        AGENT="all"
    fi

    case "$AGENT" in
        zeus|0xzeus)
            if [ -d "$AGENTS_DIR/0xzeus" ]; then
                cd "$AGENTS_DIR/0xzeus" && git pull
                msg "Zeus updated"
            else
                warn "Zeus not installed"
            fi
            ;;
        uta)
            install_uta
            msg "Uta updated"
            ;;
        orphanim)
            install_orphanim
            msg "Orphanim updated"
            ;;
        dragon|dragon-agent)
            install_dragon
            msg "Dragon updated"
            ;;
        all)
            for agent in zeus uta orphanim dragon; do
                if is_installed "$agent"; then
                    update_agent "$agent"
                fi
            done
            ;;
        *)
            error "Unknown agent: $AGENT"
            ;;
    esac
}

show_status() {
    echo "=== Y7 Agents Status ==="
    echo ""
    echo "Agents Directory: $AGENTS_DIR"
    echo ""

    for agent in zeus uta orphanim dragon; do
        echo -n "$agent: "
        if is_installed "$agent"; then
            echo -e "${GREEN}installed${NC}"
        else
            echo -e "${RED}not installed${NC}"
        fi
    done

    echo ""
    echo "API Keys configured:"
    [ -n "$DEEPSEEK_API_KEY" ] && echo -e "  ${GREEN}✓${NC} DEEPSEEK_API_KEY" || echo -e "  ${RED}✗${NC} DEEPSEEK_API_KEY"
    [ -n "$OPENROUTER_API_KEY" ] && echo -e "  ${GREEN}✓${NC} OPENROUTER_API_KEY" || echo -e "  ${RED}✗${NC} OPENROUTER_API_KEY"
    [ -n "$OPENAI_API_KEY" ] && echo -e "  ${GREEN}✓${NC} OPENAI_API_KEY" || echo -e "  ${RED}✗${NC} OPENAI_API_KEY"

    echo ""
    echo "Ollama (local):"
    if command -v ollama &>/dev/null && pgrep -x ollama &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} Running"
    else
        echo -e "  ${YELLOW}○${NC} Not running (agents can use local Ollama)"
    fi
}

# Main
case "${1:-}" in
    list|ls)
        list_agents
        ;;
    install|i)
        shift
        install_agent "$@"
        ;;
    remove|rm|uninstall)
        shift
        remove_agent "$@"
        ;;
    run|r)
        shift
        run_agent "$@"
        ;;
    update|upgrade)
        shift
        update_agent "$@"
        ;;
    status)
        show_status
        ;;
    -h|--help|help)
        show_help
        ;;
    "")
        list_agents
        ;;
    *)
        # Try to run as agent name
        run_agent "$@"
        ;;
esac
